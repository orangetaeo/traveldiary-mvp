{
  "name": "traveldiary-mvp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "sh ./scripts/start.sh",
    "lint": "next lint --dir app --dir components --dir lib --dir actions --dir tests",
    "lint:ci": "next lint --max-warnings 0 --dir app --dir components --dir lib --dir actions --dir tests",
    "postinstall": "prisma generate || true",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test:e2e": "playwright test",
    "test:e2e:live": "PLAYWRIGHT_BASE_URL=https://traveldiary-mvp-production.up.railway.app playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "quarantine:cleanup": "node scripts/quarantine-cleanup.mjs",
    "autonomy:clear-paused": "node scripts/clear-autonomy-paused.mjs",
    "seed:nearby": "npx tsx scripts/seed-pipeline/01-google-nearby.ts",
    "seed:details": "npx tsx scripts/seed-pipeline/02-google-details.ts",
    "seed:naver": "npx tsx scripts/seed-pipeline/03-naver-evidence.ts",
    "seed:merge": "npx tsx scripts/seed-pipeline/04-merge-dedupe.ts",
    "seed:shopping": "npx tsx scripts/seed-pipeline/01b-shopping-boost.ts",
    "seed:refine": "npx tsx scripts/seed-pipeline/05-phase-b-refine.ts",
    "seed:export": "npx tsx scripts/seed-pipeline/06-export-discover.ts",
    "seed:all": "npx tsx scripts/seed-pipeline/01-google-nearby.ts && npx tsx scripts/seed-pipeline/01b-shopping-boost.ts && npx tsx scripts/seed-pipeline/02-google-details.ts && npx tsx scripts/seed-pipeline/03-naver-evidence.ts && npx tsx scripts/seed-pipeline/04-merge-dedupe.ts && npx tsx scripts/seed-pipeline/05-phase-b-refine.ts && npx tsx scripts/seed-pipeline/06-export-discover.ts",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "autoprefixer": "^10.4.19",
    "jose": "^6.2.3",
    "next": "^14.2.35",
    "pg": "^8.20.0",
    "postcss": "^8.4.39",
    "prisma": "^7.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "tsx": "^4.21.0",
    "vitest": "^2.1.9"
  }
}
