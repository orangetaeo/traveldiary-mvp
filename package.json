{
  "name": "traveldiary-mvp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "sh ./scripts/start.sh",
    "lint": "next lint --dir app --dir components --dir lib --dir actions",
    "lint:ci": "next lint --max-warnings 0 --dir app --dir components --dir lib --dir actions",
    "postinstall": "prisma generate || true",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test:e2e": "playwright test",
    "test:e2e:live": "PLAYWRIGHT_BASE_URL=https://traveldiary-mvp-production.up.railway.app playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "autoprefixer": "^10.4.19",
    "jose": "^6.2.3",
    "next": "^14.2.35",
    "pg": "^8.20.0",
    "postcss": "^8.4.39",
    "prisma": "^7.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "vitest": "^2.1.9"
  }
}
