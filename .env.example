# ============================================
# TRAVELDIARY MVP — 환경 변수 템플릿
# ============================================
# .env.local 만들기:  cp .env.example .env.local
# .env.local은 git에 올라가지 않습니다 (.gitignore).
#
# 사이클 5a: 모두 빈 칸 — 데모 모드 배포 가능 (ADR-009/016).
# 사이클 5b: PostgreSQL + 외부 API 도입 시 채움 (ADR-013 예정).
# ============================================

# ── 앱 ────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=

# ── 인증 (사이클 11b OAuth, ADR-026) ─
# 카카오 개발자 콘솔 → REST API 키
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# JWT_SECRET — openssl rand -hex 32 (32바이트 이상 hex)
JWT_SECRET=
# Admin 대시보드 접근 키 — /admin/* 페이지에 ?key=<값>으로 전달 (BLOCKER 3)
ADMIN_SECRET_KEY=

# ── DB (사이클 5b에서 채움) ────────────────
# Railway PostgreSQL 추가 시 자동 주입됨
DATABASE_URL=

# ── AI 모델 (사이클 5b — Claude 또는 OpenAI) ─
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Google Cloud (사이클 5b — Places·Directions·Vision·Maps) ─
GOOGLE_CLOUD_API_KEY=
GOOGLE_VISION_CREDENTIALS=
GOOGLE_PLACES_API_KEY=
GOOGLE_DIRECTIONS_API_KEY=
# 사이클 7.5 ADR-028 — Embed API 키 (HTTP referrer 화이트리스트 필수)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# ── 네이버 검색 API (사이클 5b — 블로그 후기 인덱싱) ─
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── OTA 어필리에이트 + API (사이클 12a/12b, ADR-025/027) ─
KLOOK_AFFILIATE_ID=
KKDAY_AFFILIATE_ID=
AGODA_AFFILIATE_ID=
# 12b 실 API 통합 (어필리에이트 계약 후 발급)
KLOOK_API_KEY=
KKDAY_API_KEY=
AGODA_API_KEY=
