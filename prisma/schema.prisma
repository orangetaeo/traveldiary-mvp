// TravelDiary — Prisma Schema (사이클 1 / 0001_init_pqc)
// 결정: ADR-004 (Prisma 7 + PostgreSQL), ADR-006 (DAG 인접 리스트), ADR-009 (푸꾸옥 시드)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════
// USER
// ═══════════════════════════════════════════

model User {
  id          String   @id @default(cuid())

  email       String?  @unique @db.VarChar(320)
  kakaoId     String?  @unique @db.VarChar(40)
  name        String?  @db.VarChar(80)

  preferences Json?

  trips          Trip[]
  members        TripMember[]
  shareComments  ShareComment[]
  checklistItems ChecklistItem[]
  costEntries    CostEntry[]
  itineraryItems ItineraryItem[]
  votes          Vote[]
  reviews        TripReview[]
  tripPhotos     TripPhoto[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt])
}

// ═══════════════════════════════════════════
// TRIP
// ═══════════════════════════════════════════

model Trip {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id])

  destination     String   @db.VarChar(80)
  destinationCode String   @db.VarChar(20)
  startDate       DateTime
  nights          Int

  companion       String
  preferences     Json

  status          String   @default("draft")
  currentMode     String   @default("pre-travel")

  items           ItineraryItem[]
  members         TripMember[]
  checklistItems  ChecklistItem[]
  costEntries     CostEntry[]
  shareLinks      ShareLink[]
  votes           Vote[]
  reviews         TripReview[]
  photos          TripPhoto[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([ownerId, status])
  @@index([startDate])
  @@index([destinationCode])
  @@index([deletedAt])
}

// ═══════════════════════════════════════════
// ITINERARY ITEM (DAG 노드)
// ═══════════════════════════════════════════

model ItineraryItem {
  id              String   @id @default(cuid())
  tripId          String
  trip            Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  dayIndex        Int
  scheduledAt     DateTime
  durationMinutes Int

  flexibility     String
  priority        Int
  flexMinutes     Int      @default(0)

  name            String   @db.VarChar(200)
  category        String

  locationLat     Float
  locationLng     Float
  locationAddress String   @db.VarChar(500)

  estimatedPrice  Json?
  bookingStatus   Json?

  evidence        Json

  /** 사이클 7 (ADR-023) — 외부 이미지 URL 배열, 0~5장 권장 */
  photos          String[] @default([])

  dependents      ItineraryDependency[] @relation("dependency")
  dependencies    ItineraryDependency[] @relation("dependent")

  validations     ValidationResult[]

  /**
   * 사이클 BLOCKER6 (마이그 0014) — 작성자 user.id.
   * NULL = legacy / DEMO_TRIP_ID / 미인증. 생성 시점에만 stamp.
   */
  actorId         String?
  actor           User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tripId, dayIndex])
  @@index([tripId, scheduledAt])
  @@index([category])
  @@index([actorId])
}

model ItineraryDependency {
  id           String        @id @default(cuid())
  dependentId  String
  dependencyId String
  dependent    ItineraryItem @relation("dependent", fields: [dependentId], references: [id], onDelete: Cascade)
  dependency   ItineraryItem @relation("dependency", fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([dependentId, dependencyId])
  @@index([dependencyId])
}

// ═══════════════════════════════════════════
// VALIDATION (5단계 검증 결과 — 환각 차단)
// ═══════════════════════════════════════════

model ValidationResult {
  id                String        @id @default(cuid())
  itemId            String
  item              ItineraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  placeExists       Boolean
  operatingStatus   String
  bookingRequired   Boolean
  distanceVerified  Boolean
  priceVerified     Boolean

  /** 사이클 E (ADR-031) — enum status 평탄화 해소. 기존 row NULL 허용. */
  priceStatus       String?
  distanceStatus    String?

  validatedAt       DateTime      @default(now())

  @@index([itemId, validatedAt])
}

// ═══════════════════════════════════════════
// COLLABORATION
// ═══════════════════════════════════════════

model TripMember {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  role      String
  joinedAt  DateTime @default(now())

  @@unique([tripId, userId])
  @@index([userId])
}

// ═══════════════════════════════════════════
// AUDIT LOG (S-13 절대 규칙)
// ═══════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())

  actorId    String?
  action     String
  resource   String
  resourceId String

  before     Json?
  after      Json?
  metadata   Json?

  createdAt  DateTime @default(now())

  @@index([resource, resourceId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// ═══════════════════════════════════════════
// M6 — CHECKLIST (사이클 9, ADR-022)
// ═══════════════════════════════════════════

model ChecklistItem {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  /** "documents" | "clothing" | "electronics" | "forbidden" | "declarable" | "custom" */
  category    String
  text        String
  /** "D-30" | "D-14" | "D-7" | "D-1" | "during" | "after" */
  dDayBucket  String
  done        Boolean  @default(false)
  /** 도시별 특이사항 (시드 City와 결합 시 표시) */
  cityNote    String?
  /** 같은 dDayBucket 내 정렬 */
  sortOrder   Int      @default(0)

  /**
   * 사이클 TT (ADR-045) — 작성자 user.id. OAuth 활성 후 매핑.
   * NULL = legacy / DEMO_TRIP_ID / 미인증. 생성 시점에만 stamp, 이후 mutation은 보존.
   */
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tripId, dDayBucket])
  @@index([tripId, done])
  @@index([actorId])
}

// ═══════════════════════════════════════════
// M6 — COST (사이클 9, ADR-022)
// ═══════════════════════════════════════════

model CostEntry {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  date        DateTime
  label       String

  amountKrw   Int
  /** { value: number, currency: string } — 환율 산출은 city.payment.approxKrwRate */
  amountLocal Json?

  /** "paid" | "booked" | "planned" */
  status      String   @default("planned")
  /** "food" | "transport" | "accommodation" | "shopping" | "activity" | "other" 또는 자유 */
  category    String?
  /** ["userId-1", ...] — 사이클 11 OAuth 후 활성. 9에선 빈 배열 또는 null */
  splitWith   Json?

  /**
   * 사이클 UU (ADR-042) — 정산 완료 마커 (E1 v3 미니).
   * NULL = 미정산 / NOT NULL = 정산 완료 시점.
   * computeSettlement에서 NOT NULL인 entry는 흐름 계산에서 제외.
   */
  settledAt   DateTime?

  /**
   * 사이클 BLOCKER6 (마이그 0014) — 작성자 user.id.
   * NULL = legacy / DEMO_TRIP_ID / 미인증. 생성 시점에만 stamp.
   */
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tripId, date])
  @@index([tripId, status])
  @@index([tripId, settledAt])
  @@index([actorId])
}

// ═══════════════════════════════════════════
// M7 — SHARE LINK (사이클 11a, ADR-024)
// ═══════════════════════════════════════════

model ShareLink {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  /** URL 노출 토큰 — 충분히 unguessable (cuid) */
  syncKey     String    @unique
  /** "view" | "edit" — 11a는 view만, edit는 11b OAuth 후 */
  permission  String    @default("view")
  expiresAt   DateTime?
  /** 11a는 null, 11b OAuth 후 사용자 ID */
  createdBy   String?

  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  /** 사이클 R (ADR-036) — 익명 댓글/리액션 */
  comments    ShareComment[]

  @@index([syncKey])
  @@index([tripId])
}

// ═══════════════════════════════════════════
// 사이클 R (ADR-036) — 익명 협업 댓글/리액션
// ═══════════════════════════════════════════

model ShareComment {
  id          String    @id @default(cuid())
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  /** trip 전체 댓글이면 null, 일정별이면 ItineraryItem.id */
  itemId      String?
  /** 표시 닉네임 — 2~10자, XSS escape 후 저장 (escape 4배 여유 → 50) */
  nickname    String    @db.VarChar(50)
  /** 본문 — validateBody 200자, escape 4배 여유 → 800은 과함. 200자 + escape 안전 마진 → 1000 */
  body        String    @db.VarChar(1000)
  /** 가벼운 투표 흡수: "LIKE" | "DISLIKE" | "QUESTION" | null */
  reaction    String?
  /** 본인 식별 토큰 (LocalStorage UUID) — OAuth 없이 본인 삭제 권한 */
  clientUuid  String
  /** OAuth 활성 후 user.id 매핑. 사이클 HH (ADR-038) — User FK + ON DELETE SET NULL */
  actorId     String?
  actor       User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([shareLinkId])
  @@index([clientUuid])
  @@index([deletedAt])
  @@index([actorId])
}

// ═══════════════════════════════════════════
// C4 — VOTE (사이클 E)
// ═══════════════════════════════════════════

model Vote {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  question    String
  /** [{ "label": "추천1", "voters": ["userId1"] }, ...] */
  options     Json
  status      String   @default("open") // "open" | "closed"
  decidedAt   DateTime?

  createdBy   String?
  /**
   * 사이클 BLOCKER6 (마이그 0014) — 작성자 user.id + FK.
   * createdBy 유지 (BC). 신규 코드는 actorId 사용.
   */
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([tripId, status])
  @@index([actorId])
}

// ═══════════════════════════════════════════
// PLACE (시드 장소 풀 — 파이프라인 800곳+)
// ═══════════════════════════════════════════

model Place {
  id              String   @id @default(cuid())
  googlePlaceId   String?  @unique
  cityCode        String   @db.VarChar(10)  // "PQC", "DAD"

  name            String   @db.VarChar(200) // 한글 우선
  nameLocal       String?  @db.VarChar(200) // 현지어

  category        String   // "food" | "spot" | "shopping" | "rest"
  subCategory     String?  // "카페", "해변", "야시장" 등

  lat             Float
  lng             Float
  address         String   @db.VarChar(500)

  photos          String[] @default([])
  rating          Float?
  userRatingsTotal Int?
  priceLevel      Int?
  estimatedPrice  Json?    // { amount, currency }

  evidence        Json     // { reasons, sources, verifiedAt, warnings? }
  qualityScore    Float    @default(0)
  zone            String?  // 수집 구역 ID

  isActive        Boolean  @default(true)
  defaultDurationMinutes Int @default(60)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([cityCode, category])
  @@index([cityCode, qualityScore])
  @@index([isActive])
}

// ═══════════════════════════════════════════
// E2 — TRIP REVIEW (여행 후기 DB 영속화)
// ═══════════════════════════════════════════

model TripReview {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  rating    Int      @default(0)
  text      String   @default("") @db.VarChar(2000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, actorId])
  @@index([tripId])
  @@index([actorId])
}

// ═══════════════════════════════════════════
// E3 — TRIP PHOTO (여행 사진 앨범)
// ═══════════════════════════════════════════

model TripPhoto {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  // base64 data URL 지원을 위해 Text (사진 1장당 ~200~400KB → VARCHAR(500) 초과)
  url       String   @db.Text
  caption   String?  @db.VarChar(200)
  dayIndex  Int?
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())

  @@index([tripId, dayIndex])
  @@index([actorId])
}

// ═══════════════════════════════════════════
// EVIDENCE CACHE (Phase 1 외부 API 호출 비용 절감)
// ═══════════════════════════════════════════

model EvidenceCache {
  id           String   @id @default(cuid())
  placeId      String
  platform     String

  data         Json

  fetchedAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([placeId, platform])
  @@index([expiresAt])
}
