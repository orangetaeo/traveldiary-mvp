// TravelDiary — Prisma Schema (사이클 1 / 0001_init_pqc)
// 결정: ADR-004 (Prisma 7 + PostgreSQL), ADR-006 (DAG 인접 리스트), ADR-009 (푸꾸옥 시드)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════
// USER
// ═══════════════════════════════════════════

model User {
  id          String   @id @default(cuid())

  email       String?  @unique
  kakaoId     String?  @unique
  name        String?

  preferences Json?

  trips       Trip[]
  members     TripMember[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt])
}

// ═══════════════════════════════════════════
// TRIP
// ═══════════════════════════════════════════

model Trip {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id])

  destination     String
  destinationCode String
  startDate       DateTime
  nights          Int

  companion       String
  preferences     Json

  status          String   @default("draft")
  currentMode     String   @default("pre-travel")

  items           ItineraryItem[]
  members         TripMember[]
  checklistItems  ChecklistItem[]
  costEntries     CostEntry[]
  shareLinks      ShareLink[]
  votes           Vote[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([ownerId, status])
  @@index([startDate])
  @@index([destinationCode])
  @@index([deletedAt])
}

// ═══════════════════════════════════════════
// ITINERARY ITEM (DAG 노드)
// ═══════════════════════════════════════════

model ItineraryItem {
  id              String   @id @default(cuid())
  tripId          String
  trip            Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  dayIndex        Int
  scheduledAt     DateTime
  durationMinutes Int

  flexibility     String
  priority        Int
  flexMinutes     Int      @default(0)

  name            String
  category        String

  locationLat     Float
  locationLng     Float
  locationAddress String

  estimatedPrice  Json?
  bookingStatus   Json?

  evidence        Json

  /** 사이클 7 (ADR-023) — 외부 이미지 URL 배열, 0~5장 권장 */
  photos          String[] @default([])

  dependents      ItineraryDependency[] @relation("dependency")
  dependencies    ItineraryDependency[] @relation("dependent")

  validations     ValidationResult[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tripId, dayIndex])
  @@index([tripId, scheduledAt])
  @@index([category])
}

model ItineraryDependency {
  id           String        @id @default(cuid())
  dependentId  String
  dependencyId String
  dependent    ItineraryItem @relation("dependent", fields: [dependentId], references: [id], onDelete: Cascade)
  dependency   ItineraryItem @relation("dependency", fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([dependentId, dependencyId])
  @@index([dependencyId])
}

// ═══════════════════════════════════════════
// VALIDATION (5단계 검증 결과 — 환각 차단)
// ═══════════════════════════════════════════

model ValidationResult {
  id                String        @id @default(cuid())
  itemId            String
  item              ItineraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  placeExists       Boolean
  operatingStatus   String
  bookingRequired   Boolean
  distanceVerified  Boolean
  priceVerified     Boolean

  /** 사이클 E (ADR-031) — enum status 평탄화 해소. 기존 row NULL 허용. */
  priceStatus       String?
  distanceStatus    String?

  validatedAt       DateTime      @default(now())

  @@index([itemId, validatedAt])
}

// ═══════════════════════════════════════════
// COLLABORATION
// ═══════════════════════════════════════════

model TripMember {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  role      String
  joinedAt  DateTime @default(now())

  @@unique([tripId, userId])
  @@index([userId])
}

// ═══════════════════════════════════════════
// AUDIT LOG (S-13 절대 규칙)
// ═══════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())

  actorId    String?
  action     String
  resource   String
  resourceId String

  before     Json?
  after      Json?
  metadata   Json?

  createdAt  DateTime @default(now())

  @@index([resource, resourceId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

// ═══════════════════════════════════════════
// M6 — CHECKLIST (사이클 9, ADR-022)
// ═══════════════════════════════════════════

model ChecklistItem {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  /** "documents" | "clothing" | "electronics" | "forbidden" | "declarable" | "custom" */
  category    String
  text        String
  /** "D-30" | "D-14" | "D-7" | "D-1" | "during" | "after" */
  dDayBucket  String
  done        Boolean  @default(false)
  /** 도시별 특이사항 (시드 City와 결합 시 표시) */
  cityNote    String?
  /** 같은 dDayBucket 내 정렬 */
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tripId, dDayBucket])
  @@index([tripId, done])
}

// ═══════════════════════════════════════════
// M6 — COST (사이클 9, ADR-022)
// ═══════════════════════════════════════════

model CostEntry {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  date        DateTime
  label       String

  amountKrw   Int
  /** { value: number, currency: string } — 환율 산출은 city.payment.approxKrwRate */
  amountLocal Json?

  /** "paid" | "booked" | "planned" */
  status      String   @default("planned")
  /** "food" | "transport" | "accommodation" | "shopping" | "activity" | "other" 또는 자유 */
  category    String?
  /** ["userId-1", ...] — 사이클 11 OAuth 후 활성. 9에선 빈 배열 또는 null */
  splitWith   Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tripId, date])
  @@index([tripId, status])
}

// ═══════════════════════════════════════════
// M7 — SHARE LINK (사이클 11a, ADR-024)
// ═══════════════════════════════════════════

model ShareLink {
  id          String    @id @default(cuid())
  tripId      String
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  /** URL 노출 토큰 — 충분히 unguessable (cuid) */
  syncKey     String    @unique
  /** "view" | "edit" — 11a는 view만, edit는 11b OAuth 후 */
  permission  String    @default("view")
  expiresAt   DateTime?
  /** 11a는 null, 11b OAuth 후 사용자 ID */
  createdBy   String?

  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  /** 사이클 R (ADR-036) — 익명 댓글/리액션 */
  comments    ShareComment[]

  @@index([syncKey])
  @@index([tripId])
}

// ═══════════════════════════════════════════
// 사이클 R (ADR-036) — 익명 협업 댓글/리액션
// ═══════════════════════════════════════════

model ShareComment {
  id          String    @id @default(cuid())
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  /** trip 전체 댓글이면 null, 일정별이면 ItineraryItem.id */
  itemId      String?
  /** 표시 닉네임 — 2~10자, XSS escape 후 저장 (escape 4배 여유 → 50) */
  nickname    String    @db.VarChar(50)
  /** 본문 — validateBody 200자, escape 4배 여유 → 800은 과함. 200자 + escape 안전 마진 → 1000 */
  body        String    @db.VarChar(1000)
  /** 가벼운 투표 흡수: "LIKE" | "DISLIKE" | "QUESTION" | null */
  reaction    String?
  /** 본인 식별 토큰 (LocalStorage UUID) — OAuth 없이 본인 삭제 권한 */
  clientUuid  String
  /** OAuth 활성 후 user.id 매핑 (nullable, 마이그 없이 자연 통합) */
  actorId     String?

  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  @@index([shareLinkId])
  @@index([clientUuid])
  @@index([deletedAt])
}

// ═══════════════════════════════════════════
// C4 — VOTE (사이클 E)
// ═══════════════════════════════════════════

model Vote {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  question    String
  /** [{ "label": "추천1", "voters": ["userId1"] }, ...] */
  options     Json
  status      String   @default("open") // "open" | "closed"
  decidedAt   DateTime?

  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([tripId, status])
}

// ═══════════════════════════════════════════
// EVIDENCE CACHE (Phase 1 외부 API 호출 비용 절감)
// ═══════════════════════════════════════════

model EvidenceCache {
  id           String   @id @default(cuid())
  placeId      String
  platform     String

  data         Json

  fetchedAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([placeId, platform])
  @@index([expiresAt])
}
